NEXT_PUBLIC_ENV=
NEXT_PUBLIC_GAP_INDEXER_URL=
NEXT_PUBLIC_ALCHEMY_KEY=
NEXT_PUBLIC_PROJECT_ID=
NEXT_PUBLIC_MIXPANEL_KEY=
NEXT_PUBLIC_GA_TRACKING_ID=
NEXT_PUBLIC_RPC_MAINNET=
NEXT_PUBLIC_RPC_OPTIMISM=
NEXT_PUBLIC_RPC_ARBITRUM=
NEXT_PUBLIC_RPC_CELO=
NEXT_PUBLIC_RPC_BASE=
NEXT_PUBLIC_RPC_SEI=
NEXT_PUBLIC_RPC_BASE_SEPOLIA=
NEXT_PUBLIC_RPC_OPTIMISM_SEPOLIA=
NEXT_PUBLIC_RPC_SEPOLIA=
NEXT_PUBLIC_IPFS_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_VERCEL_ENV=
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_ALCHEMY_POLICY_ID=
NEXT_PUBLIC_AMPLITUDE_KEY=
NEXT_PUBLIC_RPC_LISK=
NEXT_PUBLIC_RPC_SCROLL=
NEXT_PUBLIC_E2E_AUTH_BYPASS=false

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Funding-platform link targets. Leave UNSET to use the runtime-host heuristic:
# same-origin links (/community/<slug>/programs/...) on localhost so local QA stays on
# its own origin, external tenant domains when deployed. Set "true" to force external
# tenant domains (e.g. a deploy preview that should link out), "false" to force
# same-origin links. See utilities/fundingPlatformUrls.ts.
NEXT_PUBLIC_FUNDING_PLATFORM_EXTERNAL_LINKS=

# Shared secret for Vercel Cron requests (vercel.json crons). When set, Vercel
# sends it as 'Authorization: Bearer …' and /api/cron/* routes require it.
CRON_SECRET=

# Sanity Blog CMS. All optional — unset means the blog content gateway
# returns empty results and /blog renders its empty state instead of
# crashing the build. See sanity/env.ts, sanity/lib/client.ts.
# Sanity project id (dashboard.sanity.io > project settings).
NEXT_PUBLIC_SANITY_PROJECT_ID=
# Dataset name. Defaults to "production" when unset.
NEXT_PUBLIC_SANITY_DATASET=
# Sanity API version (date-based). Defaults to "2024-01-01" when unset.
NEXT_PUBLIC_SANITY_API_VERSION=
# Server-only viewer token used to read draft content for the preview flow.
# NEVER expose this to the client — it must stay out of NEXT_PUBLIC_* vars.
SANITY_VIEWER_TOKEN=
# Shared secret verified on incoming Sanity webhook revalidation requests.
SANITY_WEBHOOK_SECRET=
# Shared secret used to authorize the /api/blog/preview draft-mode entry route.
SANITY_PREVIEW_SECRET=
