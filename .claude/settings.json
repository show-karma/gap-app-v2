{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-lint.sh",
            "timeout": 30,
            "statusMessage": "Running Biome lint..."
          },
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-antipatterns.sh",
            "timeout": 10,
            "statusMessage": "Checking anti-patterns..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit-tests.sh",
            "timeout": 120,
            "statusMessage": "Running tests before commit..."
          }
        ]
      }
    ]
  }
}
